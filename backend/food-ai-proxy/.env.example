PORT=8787
NVIDIA_API_KEY=nvapi-your-key-here

# A NVIDIA vision/multimodal model is needed for food photos.
# You can replace this with another vision model available in your NVIDIA account.
NVIDIA_VISION_MODEL=meta/llama-3.2-11b-vision-instruct

# Optional: use Nemotron 3 Ultra to normalize the vision model output into strict JSON.
# This is where nvidia/nemotron-3-ultra-550b-a55b fits best.
USE_NEMOTRON_NORMALIZER=false
NVIDIA_NORMALIZER_MODEL=nvidia/nemotron-3-ultra-550b-a55b

NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_TIMEOUT_MS=45000
MAX_UPLOAD_MB=8
