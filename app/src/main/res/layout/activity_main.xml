<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_foodai_soft"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/food_green_700"
        app:menu="@menu/main_menu"
        app:subtitleTextColor="#DFFFFFFF"
        app:title="@string/nav_home"
        app:titleTextColor="@color/white" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <ScrollView
            android:id="@+id/pageHome"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="18dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="16dp"
                    app:cardBackgroundColor="@color/food_green_700"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="5dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Calo còn lại hôm nay"
                            android:textColor="#DFFFFFFF"
                            android:textSize="15sp" />

                        <TextView
                            android:id="@+id/tvCaloriesRemaining"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="0"
                            android:textColor="@color/white"
                            android:textSize="42sp"
                            android:textStyle="bold" />

                        <ProgressBar
                            android:id="@+id/progressCalories"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="22dp"
                            android:layout_marginTop="16dp"
                            android:max="100"
                            android:progress="0"
                            android:progressDrawable="@drawable/progress_calorie_large" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/tvCaloriesConsumed"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Đã nạp: 0 kcal"
                                android:textColor="@color/white" />

                            <TextView
                                android:id="@+id/tvCaloriesTarget"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Mục tiêu: 0 kcal"
                                android:textColor="@color/white" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCamera"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:text="Chụp món ăn"
                        android:textAllCaps="false"
                        app:backgroundTint="@color/food_green_600"
                        app:cornerRadius="16dp"
                        app:icon="@drawable/ic_nav_scan" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnGallery"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:text="Thư viện"
                        android:textAllCaps="false"
                        app:cornerRadius="16dp"
                        app:icon="@android:drawable/ic_menu_gallery"
                        app:strokeColor="@color/food_green_600" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvGalleryStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="22dp"
                    android:layout_marginTop="10dp"
                    android:layout_marginEnd="22dp"
                    android:background="@color/food_green_50"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="10dp"
                    android:text="@string/gallery_picker_opening"
                    android:textColor="@color/food_text_secondary"
                    android:textSize="14sp"
                    android:visibility="gone" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginTop="18dp"
                    app:cardBackgroundColor="@color/food_surface_card"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/home_meal_list_title"
                            android:textColor="@color/food_text_primary"
                            android:textSize="19sp"
                            android:textStyle="bold" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnDietSortStatus"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="42dp"
                            android:layout_marginTop="8dp"
                            android:minWidth="0dp"
                            android:paddingHorizontal="14dp"
                            android:text="@string/home_sort_normal"
                            android:textAllCaps="false"
                            android:textColor="@color/food_green_700"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            app:cornerRadius="20dp"
                            app:strokeColor="@color/food_green_600" />

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvHomeMealSuggestions"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:clipToPadding="false"
                            android:nestedScrollingEnabled="false"
                            android:overScrollMode="never" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </ScrollView>

        <LinearLayout
            android:id="@+id/pageDiary"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="22dp"
                android:layout_marginBottom="8dp"
                android:text="Nhật ký hôm nay"
                android:textColor="@color/food_text_primary"
                android:textSize="21sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/food_surface_card"
                app:cardCornerRadius="22dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnPreviousDiaryDate"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:minWidth="0dp"
                            android:text="@string/diary_previous_day"
                            android:textAllCaps="false"
                            android:textColor="@color/food_green_700" />

                        <TextView
                            android:id="@+id/tvDiaryDate"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="@string/diary_date_today_preview"
                            android:textColor="@color/food_text_primary"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnNextDiaryDate"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:minWidth="0dp"
                            android:text="@string/diary_next_day"
                            android:textAllCaps="false"
                            android:textColor="@color/food_green_700" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvDiarySummary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:gravity="center"
                        android:text="@string/diary_summary_loading"
                        android:textColor="@color/food_text_secondary"
                        android:textSize="14sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/diaryStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="12dp"
                android:background="@color/food_green_50"
                android:gravity="center"
                android:padding="14dp"
                android:text="@string/diary_loading"
                android:textColor="@color/food_text_secondary"
                android:textSize="14sp"
                android:visibility="gone" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/diaryEmptyState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="4dp"
                android:visibility="gone"
                app:cardBackgroundColor="@color/food_green_50"
                app:cardCornerRadius="22dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="@string/diary_empty_title"
                        android:textColor="@color/food_green_900"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center"
                        android:text="@string/diary_empty_message"
                        android:textColor="@color/food_text_secondary"
                        android:textSize="14sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDiaryAddMeal"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="16dp"
                        android:text="@string/diary_empty_scan_button"
                        android:textAllCaps="false"
                        app:backgroundTint="@color/food_green_600"
                        app:cornerRadius="16dp"
                        app:icon="@drawable/ic_nav_scan" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvTodayLog"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:paddingHorizontal="16dp"
                android:paddingBottom="16dp" />
        </LinearLayout>

    </FrameLayout>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/food_surface_card"
        app:itemRippleColor="@color/food_green_100"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_nav_menu" />
</LinearLayout>
